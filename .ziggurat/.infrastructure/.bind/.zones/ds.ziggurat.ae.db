$TTL 86400
; ==============================================================================
;  [Ziggurat OS] ABSOLUTE FQDN ZONE SPECIFICATION (v1842)
;  FQDN Path Target: ds.ziggurat.ae.
; ==============================================================================
@   IN  SOA ns1.ds.ziggurat.ae. admin.ds.ziggurat.ae. (
            2026062404 ; Serial
            3600       ; Refresh
            1800       ; Retry
            604800     ; Expire
            86400 )    ; Minimum TTL

@   IN  NS  ns1.ds.ziggurat.ae.

; ==============================================================================
;  ДИНАМИЧЕСКИЙ АРХИТЕКТУРНЫЙ ИHЖЕКТ IP v1842
;  Используем строго синтаксис точки с запятой для комментариев BIND9!
; ==============================================================================
ns1.ds.ziggurat.ae. IN  A   ${ZOS_SDN_GATEWAY}
ds.ziggurat.ae.     IN  A   ${ZOS_SDN_GATEWAY}
