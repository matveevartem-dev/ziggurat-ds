; ==============================================================================
;  [Ziggurat OS] TERMINAL SERVICE DNA BLUEPRINTS SPECIFICATION (v2361)
;  Path: layers/services/ds/.ziggurat/.manifest
; ==============================================================================

[MODE]
sections = SERVICES
scope = all
terminal = true

[NETWORK]
${TENANT_UUID}-legacy-net = true
ziggurat-net = driver:bridge,subnet:${ZOS_SDN_SUBNET}/${ZOS_SDN_MASK},gateway:${ZOS_SDN_GATEWAY}

[INGRESS_UPSTREAMS]
.ziggurat/.infrastructure/.nginx/.upstreams/local.conf = nginx.ext/upstreams/${TENANT_UUID}-legacy-local.conf

[INGRESS_VHOSTS]
.ziggurat/.infrastructure/.nginx/.filters/server.conf = nginx.ext/filters/${TENANT_UUID}-legacy-server.conf

[SERVICES]
layers = local
